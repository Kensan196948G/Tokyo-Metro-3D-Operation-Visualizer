# Server
NODE_ENV=development
PORT=3000

# ODPT API
ODPT_API_TOKEN=your_odpt_api_token_here
ODPT_GTFS_URL=https://api.odpt.org/api/v4/odpt:TrainInformation?odpt:operator=odpt.Operator:TokyoMetro
ODPT_GTFS_RT_URL=https://api.odpt.org/api/v4/gtfs/realtime/TokyoMetro

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Cache
CACHE_DIR=./data/cache

# Fetch interval
FETCH_INTERVAL_SECONDS=15

# Log
LOG_LEVEL=info
