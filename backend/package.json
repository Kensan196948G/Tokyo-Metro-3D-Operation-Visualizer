{
  "name": "metro3d-backend",
  "version": "1.0.0",
  "description": "Tokyo Metro 3D Operation Visualizer - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "fetch:static": "tsx scripts/fetch-gtfs.ts",
    "fetch:realtime": "tsx scripts/fetch-gtfs-rt.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^4.27.0",
    "@fastify/cors": "^9.0.1",
    "dotenv": "^16.4.5",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "gtfs-realtime-bindings": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsx": "^4.11.0",
    "vitest": "^1.6.0",
    "@types/node": "^20.12.0"
  }
}
